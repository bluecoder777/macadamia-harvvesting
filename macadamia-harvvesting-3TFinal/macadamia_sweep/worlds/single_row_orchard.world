<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="single_row_orchard">

    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- SIMPLE DIFFERENTIAL DRIVE ROBOT -->
    <model name="demo_rosbot">
      <pose>0 0 0.12 0 0 0</pose>

      <link name="base_link">
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.05</ixx>
            <iyy>0.05</iyy>
            <izz>0.05</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>

        <collision name="base_collision">
          <geometry>
            <box>
              <size>0.35 0.25 0.12</size>
            </box>
          </geometry>
        </collision>

        <visual name="base_visual">
          <geometry>
            <box>
              <size>0.35 0.25 0.12</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.1 0.8 1</ambient>
            <diffuse>0.1 0.1 0.8 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- LEFT WHEEL -->
      <link name="left_wheel">
        <pose>0 0.17 0 1.5708 0 0</pose>
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.001</ixx>
            <iyy>0.001</iyy>
            <izz>0.001</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>left_wheel</child>
        <axis>
          <xyz>0 1 0</xyz>
        </axis>
      </joint>

      <!-- RIGHT WHEEL -->
      <link name="right_wheel">
        <pose>0 -0.17 0 1.5708 0 0</pose>
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.001</ixx>
            <iyy>0.001</iyy>
            <izz>0.001</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>right_wheel</child>
        <axis>
          <xyz>0 1 0</xyz>
        </axis>
      </joint>

      <!-- LIDAR LINK
           z raised 0.16 -> 0.24: at 0.16 the scan plane cut through the
           top of the 0.12-high base box (top at z=0.18), so rays could hit
           the robot's own chassis and create phantom "trees" behind the
           robot (rear face sits at ~0.30 m, past the 0.25 m near-range
           gate). 0.24 clears the chassis and still sees the 1.0 m noodles. -->
      <link name="laser">
        <pose>0.12 0 0.24 0 0 0</pose>

        <visual name="laser_visual">
          <geometry>
            <cylinder>
              <radius>0.04</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>

        <sensor name="laser_sensor" type="ray">
          <always_on>true</always_on>
          <visualize>true</visualize>
          <update_rate>10</update_rate>
          <ray>
            <scan>
              <horizontal>
                <samples>720</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
            </scan>
            <range>
              <min>0.05</min>
              <max>8.0</max>
              <resolution>0.01</resolution>
            </range>
          </ray>
          <plugin name="laser_plugin" filename="libgazebo_ros_ray_sensor.so">
            <ros>
              <remapping>~/out:=/scan</remapping>
            </ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>laser</frame_name>
          </plugin>
        </sensor>
      </link>

      <joint name="laser_joint" type="fixed">
        <parent>base_link</parent>
        <child>laser</child>
      </joint>

      <!-- SIMPLE PLANAR MOVE PLUGIN: moves the robot directly from /cmd_vel -->
      <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
        <ros>
          <namespace>/</namespace>
        </ros>
        <command_topic>/cmd_vel</command_topic>
        <odometry_topic>/odom</odometry_topic>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
      </plugin>


    </model>

    <!-- TREE ROW ON ROBOT RIGHT SIDE -->
    <model name="tree_1">
      <static>true</static>
      <pose>1.0 -0.45 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="tree_2">
      <static>true</static>
      <pose>1.7 -0.45 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="tree_3">
      <static>true</static>
      <pose>2.4 -0.45 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="tree_4">
      <static>true</static>
      <pose>3.1 -0.45 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.06</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
    </model>
</world>
</sdf>
